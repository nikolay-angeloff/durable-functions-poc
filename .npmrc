# Pin all installs to the public registry so package-lock "resolved" URLs stay on registry.npmjs.org.
# Corporate ~/.npmrc often maps scopes (@babel, @types, …) to Artifactory/Nexus and re-pollutes the lockfile.
registry=https://registry.npmjs.org/
always-auth=false
@azure:registry=https://registry.npmjs.org/
@babel:registry=https://registry.npmjs.org/
@esbuild:registry=https://registry.npmjs.org/
@jridgewell:registry=https://registry.npmjs.org/
@opentelemetry:registry=https://registry.npmjs.org/
@rolldown:registry=https://registry.npmjs.org/
@rollup:registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/
@typespec:registry=https://registry.npmjs.org/
@vitejs:registry=https://registry.npmjs.org/
